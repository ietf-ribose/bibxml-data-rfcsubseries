    <front>
      <title>Multipurpose Internet Mail Extensions (MIME) Part Four: Registration Procedures</title>
      <seriesInfo name="DOI" value="10.17487/RFC4289"/>
      <seriesInfo name="BCP" value="13"/>
      <seriesInfo name="RFC" value="4289"/>
      <seriesInfo name="IETF"/>
      <author initials="N." surname="Freed" fullname="N. Freed"/>
      <author initials="J." surname="Klensin" fullname="J. Klensin"/>
      <author>
        <organization>RFC Publisher</organization>
      </author>
      <author>
        <organization>RFC Series</organization>
      </author>
      <date month="December" year="2005"></date>
      <keyword>media</keyword>
      <keyword>types</keyword>
      <keyword>external</keyword>
      <keyword>body</keyword>
      <keyword>access</keyword>
      <keyword>content-transfer-encodings</keyword>
      <abstract>
        <t>&lt;p&gt;This document specifies IANA registration procedures for MIME external body access types and content-transfer-encodings.  This document specifies an Internet Best Current Practices for the Internet Community, and requests discussion and suggestions for improvements.&lt;/p&gt;</t>
      </abstract>
    </front>
